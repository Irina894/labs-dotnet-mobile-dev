<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Phoneword.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Layout Lab">

    <ScrollView>
        <VerticalStackLayout
            Padding="25"
            Spacing="20">

            <Label
                Text="Customize layout in .NET MAUI"
                FontSize="26"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label
                Text="This page demonstrates StackLayout and Grid in XAML."
                FontSize="16"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center" />

            <Border
                Padding="15"
                BackgroundColor="#F2F2F2"
                StrokeShape="RoundRectangle 15">

                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="Phoneword example"
                        FontSize="20"
                        FontAttributes="Bold" />

                    <Entry
                        x:Name="PhoneNumberText"
                        Placeholder="Enter phone number"
                        Keyboard="Telephone" />

                    <Button
                        Text="Translate"
                        Clicked="OnTranslate" />

                    <Button
                        x:Name="CallBtn"
                        Text="Call"
                        IsEnabled="False"
                        Clicked="OnCall" />

                </VerticalStackLayout>
            </Border>

            <Border
                Padding="15"
                BackgroundColor="#F2F2F2"
                StrokeShape="RoundRectangle 15">

                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="HorizontalStackLayout example"
                        FontSize="20"
                        FontAttributes="Bold" />

                    <HorizontalStackLayout
                        Spacing="10"
                        HorizontalOptions="Center">

                        <Button Text="Yes" WidthRequest="100" />
                        <Button Text="No" WidthRequest="100" />

                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <Border
                Padding="15"
                BackgroundColor="#F2F2F2"
                StrokeShape="RoundRectangle 15">

                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="Grid example"
                        FontSize="20"
                        FontAttributes="Bold" />

                    <Grid
                        RowDefinitions="Auto, Auto, Auto"
                        ColumnDefinitions="*, *"
                        RowSpacing="10"
                        ColumnSpacing="10">

                        <Label
                            Text="First name:"
                            Grid.Row="0"
                            Grid.Column="0" />

                        <Entry
                            Placeholder="Iryna"
                            Grid.Row="0"
                            Grid.Column="1" />

                        <Label
                            Text="Last name:"
                            Grid.Row="1"
                            Grid.Column="0" />

                        <Entry
                            Placeholder="Derevoriz"
                            Grid.Row="1"
                            Grid.Column="1" />

                        <Button
                            Text="Submit"
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            HorizontalOptions="Center"
                            WidthRequest="180" />

                    </Grid>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>